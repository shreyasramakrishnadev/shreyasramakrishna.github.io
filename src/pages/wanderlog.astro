---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.data.category === 'wanderlog')
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---
<Layout title="Wanderlog — Travel">
  <ul class="entry-list">
    {posts.map((post) => (
      <li>
        <a class="entry-row" href={`/entries/${post.slug}/`}>
          <span class="stamp wanderlog">wanderlog</span>
          <span class="entry-date">{post.data.date}</span>
          <h2 class="entry-title">{post.data.title}</h2>
          <p class="entry-excerpt">{post.data.excerpt}</p>
        </a>
      </li>
    ))}
  </ul>
  {posts.length === 0 && <p class="entry-excerpt">No posts here yet — check back soon.</p>}
</Layout>